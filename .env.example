# ---------------------------------------------------------------------------
# polymarket-microstructure-lab — environment template (copy to .env)
# Everything here is for READ-ONLY public data. There are no secrets, no keys,
# no wallet credentials, and no trading config — by design.
# ---------------------------------------------------------------------------

# --- Database ---
# Local quick-start (SQLite): leave as-is, or for Postgres (Docker default):
# PML_DATABASE_URL=postgresql+psycopg://lab:lab@db:5432/lab
PML_DATABASE_URL=sqlite:///./polymarket_lab.db

# --- App ---
PML_LOG_LEVEL=INFO
PML_LOG_JSON=false
PML_ENVIRONMENT=local

# --- Universe (configurable) ---
PML_ASSETS=BTC,ETH,SOL,XRP,DOGE
PML_WINDOWS_MINUTES=5,15

# --- Target wallet (REQUIRED for wallet analysis) ---
# The PUBLIC on-chain address of the bot wallet you want to investigate (0x..., 42 chars).
# Find one on https://polymarket.com (open a trader's profile; the address is in the URL).
# This is PUBLIC data only. NEVER put a private key or seed phrase here.
# You can also pass it per-command with `--wallet 0x...`.
PML_TARGET_WALLET=
# Optional human-readable label for that wallet (e.g. its Polymarket profile name).
PML_TARGET_PROFILE=

# --- Public Polymarket endpoints (override only if they change) ---
PML_GAMMA_BASE_URL=https://gamma-api.polymarket.com
PML_DATA_BASE_URL=https://data-api.polymarket.com
PML_CLOB_BASE_URL=https://clob.polymarket.com
PML_CLOB_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws/market
PML_RTDS_WS_URL=wss://ws-live-data.polymarket.com
PML_BINANCE_WS_URL=wss://stream.binance.com:9443/stream
PML_ENABLE_RTDS=true
PML_ENABLE_BINANCE_FALLBACK=true

# --- Rate limiting / reliability (be a good API citizen) ---
PML_RATE_LIMIT_PER_SEC=5
PML_RATE_LIMIT_BURST=10
PML_MAX_RETRIES=4
PML_REQUEST_BUDGET=50000

# --- Collector (conservative by default; do NOT crank to 100-300 connections) ---
PML_WS_MAX_CONNECTIONS=2
PML_COLLECTOR_POLL_SECONDS=5
PML_STALE_AFTER_SECONDS=30
PML_MAX_PRICE_JUMP=0.5

# --- Fee fallbacks (only used when a market lacks a fee schedule) ---
PML_FALLBACK_FEE_RATE=0.02

# --- API ---
# Set true to let the API process also run periodic discovery + wallet sync.
PML_API_BACKGROUND_JOBS=false

# --- Frontend (build-time) ---
NEXT_PUBLIC_API_BASE=http://localhost:8000
# Optional: pre-fill the dashboard's wallet view with your target (else just type it in the UI).
NEXT_PUBLIC_TARGET_WALLET=
NEXT_PUBLIC_TARGET_PROFILE=
